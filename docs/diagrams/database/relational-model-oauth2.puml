@startuml
title Modèle relationnel cible - OAuth2

hide circle
skinparam shadowing false
skinparam roundcorner 10

entity "oauth_clients" as oauth_clients {
    * id : UUID <<PK>>
    --
    client_id : VARCHAR(100) <<UQ>>
    client_secret : VARCHAR(255)
    enabled : BOOLEAN
    created_at : TIMESTAMP
}

entity "oauth_client_redirect_uris" as oauth_client_redirect_uris {
    * id : UUID <<PK>>
    --
    client_id : UUID <<FK>>
    redirect_uri : VARCHAR(255)
}

entity "oauth_client_grant_types" as oauth_client_grant_types {
    * id : UUID <<PK>>
    --
    client_id : UUID <<FK>>
    grant_type : VARCHAR(100)
}

entity "scopes" as scopes {
    * id : UUID <<PK>>
    --
    code : VARCHAR(100) <<UQ>>
    description : VARCHAR(255)
}

entity "oauth_client_scopes" as oauth_client_scopes {
    * client_id : UUID <<PK, FK>>
    * scope_id : UUID <<PK, FK>>
}

entity "authorizations" as authorizations {
    * id : UUID <<PK>>
    --
    authorization_code : VARCHAR(255) <<UQ>>
    user_id : UUID <<FK>>
    client_id : UUID <<FK>>
    issued_at : TIMESTAMP
    expires_at : TIMESTAMP
    revoked : BOOLEAN
}

entity "authorization_scopes" as authorization_scopes {
    * authorization_id : UUID <<PK, FK>>
    * scope_id : UUID <<PK, FK>>
}

entity "refresh_tokens" as refresh_tokens {
    * id : UUID <<PK>>
    --
    token_value : VARCHAR(500) <<UQ>>
    authorization_id : UUID <<FK>>
    expires_at : TIMESTAMP
    revoked : BOOLEAN
}

oauth_clients ||--o{ oauth_client_redirect_uris
oauth_clients ||--o{ oauth_client_grant_types
oauth_clients ||--o{ oauth_client_scopes
scopes ||--o{ oauth_client_scopes

oauth_clients ||--o{ authorizations
authorizations ||--o{ authorization_scopes
scopes ||--o{ authorization_scopes

authorizations ||--o{ refresh_tokens

@enduml
