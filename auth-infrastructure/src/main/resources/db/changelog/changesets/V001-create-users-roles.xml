<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
        "
>

    <changeSet
            id="V001-01-create-user-table"
            author="thibault.bondetti"
    >

        <createTable tableName="iam_user" >
            <column
                    name="id_iam_user"
                    type="UUID"
            >
                <constraints
                        primaryKey="true"
                        primaryKeyName="pk_iam_user"
                        nullable="false"
                />
            </column>

            <column
                    name="username"
                    type="VARCHAR(100)"
            >
                <constraints nullable="false" />
            </column>

            <column
                    name="password_hash"
                    type="VARCHAR(255)"
            >
                <constraints nullable="false" />
            </column>

            <column
                    name="enabled"
                    type="BOOLEAN"
                    defaultValueBoolean="true"
            >
                <constraints nullable="false" />
            </column>
        </createTable>

        <createIndex
                indexName="ux_iam_user_username"
                tableName="iam_user"
                unique="true"
        >
            <column name="username" />
        </createIndex>
    </changeSet>

    <changeSet
            id="V001-02-create-application-table"
            author="thibault.bondetti"
    >

        <createTable tableName="application" >
            <column
                    name="id_application"
                    type="UUID"
            >
                <constraints
                        nullable="false"
                        primaryKey="true"
                        primaryKeyName="pk_application"
                />
            </column>

            <column
                    name="code"
                    type="VARCHAR(20)"
            >
                <constraints nullable="false" />
            </column>

            <column
                    name="name"
                    type="VARCHAR(100)"
            >
                <constraints nullable="false" />
            </column>

            <column
                    name="description"
                    type="VARCHAR(500)"
            />

        </createTable>

        <createIndex
                tableName="application"
                indexName="ux_application_code"
                unique="true"
        >
            <column name="code" />
        </createIndex>

    </changeSet>

    <changeSet
            id="V001-03-create-role-table"
            author="thibault.bondetti"
    >

        <createTable tableName="role" >

            <column
                    name="id_role"
                    type="UUID"
            >
                <constraints
                        primaryKey="true"
                        primaryKeyName="pk_role"
                        nullable="false"
                />
            </column>

            <column
                    name="id_application"
                    type="UUID"
            >
                <constraints nullable="false" />
            </column>

            <column
                    name="code"
                    type="VARCHAR(50)"
            >
                <constraints nullable="false" />
            </column>

            <column
                    name="name"
                    type="VARCHAR(100)"
            >
                <constraints nullable="false" />
            </column>

            <column
                    name="description"
                    type="VARCHAR(500)"
            />
        </createTable>

        <createIndex
                tableName="role"
                indexName="ix_role_id_application"
        >

            <column name="id_application" />
        </createIndex>

        <addForeignKeyConstraint
                baseTableName="role"
                baseColumnNames="id_application"
                referencedTableName="application"
                referencedColumnNames="id_application"
                constraintName="fk_role_application"
        />

        <createIndex
                unique="true"
                tableName="role"
                indexName="ux_role_id_application_code"
        >
            <column name="id_application" />
            <column name="code" />
        </createIndex>
    </changeSet>

    <changeSet
            id="V001-04-create-iam-user-role-table"
            author="thibault.bondetti"
    >

        <createTable tableName="iam_user_role" >
            <column
                    name="id_iam_user"
                    type="UUID"
            >
                <constraints nullable="false" />
            </column>

            <column
                    name="id_role"
                    type="UUID"
            >
                <constraints nullable="false" />
            </column>
        </createTable>

        <addPrimaryKey
                tableName="iam_user_role"
                columnNames="id_iam_user, id_role"
                constraintName="pk_iam_user_role"
        />

        <addForeignKeyConstraint
                baseTableName="iam_user_role"
                baseColumnNames="id_iam_user"
                referencedTableName="iam_user"
                referencedColumnNames="id_iam_user"
                constraintName="fk_iam_user_role_user"
                onDelete="CASCADE"
        />

        <addForeignKeyConstraint
                baseTableName="iam_user_role"
                baseColumnNames="id_role"
                referencedTableName="role"
                referencedColumnNames="id_role"
                constraintName="fk_iam_user_role_role"
                onDelete="CASCADE"
        />

        <createIndex
                indexName="ix_iam_user_role_id_iam_user"
                tableName="iam_user_role"
        >
            <column name="id_iam_user" />
        </createIndex>

        <createIndex
                indexName="ix_iam_user_role_id_role"
                tableName="iam_user_role"
        >
            <column name="id_role" />
        </createIndex>
    </changeSet>
</databaseChangeLog>